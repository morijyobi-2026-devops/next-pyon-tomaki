{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "timezone": "Asia/Tokyo",
  "schedule": [
    "before 5am on Monday",
    "before 5am on Thursday"
  ],
  "npm": {
    "minimumReleaseAge": "3 days"
  },
  "packageRules": [
    {
      "description": "Disable automerge for major updates",
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "description": "Enable automerge for minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    }
  ],
  "vulnerabilityAlerts": {
    "automerge": true,
    "automergeType": "pr"
  }
}
